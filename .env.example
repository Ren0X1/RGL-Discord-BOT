# ===== Token del bot (NO lo compartas con nadie) =====
DISCORD_TOKEN=pega_aqui_tu_token

# ID de tu servidor (opcional, hace que los comandos / aparezcan al instante)
GUILD_ID=

# ===== 1) Logs =====
LOG_CHANNEL_ID=
LOG_VOICE=true
LOG_BOTS=false

# ===== 2) Canales de voz temporales =====
MAIN_VOICE_CHANNEL_ID=
TEMP_VOICE_CATEGORY_ID=
TEMP_VOICE_LIMIT=10
TEMP_VOICE_NAME=Voz-{name}

# ===== 4) Streams =====
STREAM_ANNOUNCE_CHANNEL_ID=
STREAM_ROLE_IDS=
STREAM_MENTION=@everyone

# ===== 5) Eventos: aviso @everyone antes de empezar/acabar =====
EVENT_ANNOUNCE_CHANNEL_ID=
EVENT_LEAD_MINUTES=10

# ===== 6) Bienvenida / despedida + autorol =====
WELCOME_CHANNEL_ID=
WELCOME_MESSAGE=¡Bienvenido/a {user} a {server}! 🎉
GOODBYE_MESSAGE={user} ha salido del servidor. 👋
AUTOROLE_ID=

# ===== 7) Scrim (repartir equipos de voz) =====
SCRIM_TEAM1_CHANNEL_ID=
SCRIM_TEAM2_CHANNEL_ID=

# ===== 8) Auto-reacción: reacciona a los mensajes de quien tenga este rol =====
REACT_ROLE_ID=
# Lista de emojis separados por espacios o comas. Si lo dejas vacío usa muchas caras por defecto.
REACT_EMOJIS=
# ¿Incluir también los emojis propios del servidor en el sorteo? (true/false)
REACT_USE_SERVER_EMOJIS=true
# Probabilidad de reaccionar a un mensaje (0.1 = 1 de cada 10 aprox.)
REACT_CHANCE=0.1

# ===== 9) Aviso al owner cuando el bot arranca =====
OWNER_USER_ID=

# ===== Status del bot (bola amarilla + enlace) =====
STATUS_TEXT=loscolegones.com
STATUS_URL=https://loscolegones.com

# ===== Panel web de control =====
PANEL_PASSWORD=pon_una_contraseña_fuerte
PANEL_PORT=8080
PANEL_SECRET_KEY=

# ===== General =====
TIMEZONE=Europe/Madrid

# ===== 10) Canales-contador (estadísticas en el nombre) =====
# Crea 2 canales de VOZ, ponlos arriba del todo y pega aquí sus IDs.
STATS_MEMBERS_CHANNEL_ID=
STATS_VOICE_CHANNEL_ID=
STATS_MEMBERS_NAME=👥 Miembros: {count}
STATS_VOICE_NAME=🔊 En voz: {count}
STATS_COUNT_BOTS=false
STATS_UPDATE_SECONDS=360

# ===== Panel: HTTPS local (opcional) =====
# Rutas al certificado y la clave. Si ambos existen, el panel sirve por HTTPS.
PANEL_SSL_CERT=
PANEL_SSL_KEY=

# ===== 11) Auto-sincronizar la plantilla del servidor =====
# Pon true para que el bot mantenga al día la plantilla del servidor.
# Necesita el permiso "Gestionar servidor". No crea plantillas, solo sincroniza las existentes.
TEMPLATE_AUTO_SYNC=false
TEMPLATE_SYNC_MINUTES=60

# ===== 12) Sistema de tickets =====
# Canal donde se publica el panel (con /ticket_panel). Bloquéalo para que solo esté el panel.
TICKET_PANEL_CHANNEL_ID=
# Categoría dentro de la que se crean los canales de ticket.
TICKET_CATEGORY_ID=
# Roles que pueden atender y cerrar tickets (separados por coma o espacio).
TICKET_STAFF_ROLE_IDS=
# Textos (opcionales)
TICKET_PANEL_TITLE=🎫 Soporte
TICKET_PANEL_TEXT=¿Necesitas ayuda? Pulsa el botón de abajo para abrir un ticket y el staff te atenderá.
TICKET_OPEN_MESSAGE=Gracias por abrir un ticket. Explica tu consulta y el staff te atenderá lo antes posible.

# ===== 13) Charla con IA (gratis) en un canal =====
# Canal donde el bot vacila con IA. Déjalo vacío para desactivar.
AI_CHANNEL_ID=
# Probabilidad de responder a un mensaje (0.25 = 1 de cada 4).
AI_CHANCE=0.25
# API compatible con OpenAI. Por defecto Groq (GRATIS, sin tarjeta): saca la clave en https://console.groq.com
AI_API_BASE=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=150
AI_COOLDOWN=6
# Nº de mensajes recientes que se pasan a la IA como contexto de la conversación.
AI_HISTORY=20
# Que la IA guarde sola datos relevantes (ai_saved.json) y los use junto al contexto.
AI_MEMORY=true
# Resumen diario gracioso del chat: canal donde postearlo (vacío = desactivado) y hora (0-23).
AI_SUMMARY_CHANNEL_ID=
AI_SUMMARY_HOUR=11
# Personalidad (opcional; si lo dejas vacío usa una de pibe vacilón por defecto).
AI_SYSTEM_PROMPT=

# Contexto del servidor para la IA (vale para todos). También editable con /ia_contexto_server.
AI_SERVER_CONTEXT=
